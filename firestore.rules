rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;

      // Helper: list of every field a user document may contain
      function allowedUserFields() {
        return ['name', 'age', 'gender', 'profileVisibility', 'city', 'bio',
                'interests', 'identity', 'whatsapp', 'instagram', 'linkedin', 'photoURL',
                'createdAt', 'upcomingTrips', 'pastTrips', 'connections',
                'onboardingComplete', 'email'];
      }

      // Shared field-value validation (used by both create & update)
      function validUserData() {
        let d = request.resource.data;
        return d.name is string && d.name.size() >= 1 && d.name.size() <= 100
            && d.age is int && d.age >= 13 && d.age <= 120
            && d.gender is string && d.gender in ['Male', 'Female']
            && d.bio is string && d.bio.size() <= 500
            && d.whatsapp is string && d.whatsapp.size() <= 50
            && d.instagram is string && d.instagram.size() <= 50
            && d.interests is list && d.interests.size() <= 20
            && d.onboardingComplete is bool;
      }

      // Partial document for initial signup (before onboarding)
      function validPartialCreate() {
        let d = request.resource.data;
        return d.onboardingComplete == false
            && d.email is string;
      }

      allow create: if request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(allowedUserFields())
                    && (validUserData() || validPartialCreate());

      // Own profile: full validation. Other user: only connections field if self is involved.
      allow update: if request.auth != null
                    && request.resource.data.keys().hasOnly(allowedUserFields())
                    && (
                      (request.auth.uid == userId && validUserData())
                      || (request.auth.uid != userId
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['connections']))
                    );
    }

    // ── Waitlist ────────────────────────────────────────────
    match /waitlist/{docId} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasAll(['email', 'createdAt']);
      allow update, delete: if false;
    }

    // ── Connection Requests ────────────────────────────────
    match /connectionRequests/{requestId} {
      // Both sender and receiver may read
      allow read: if request.auth != null
                  && (resource.data.fromUserId == request.auth.uid
                      || resource.data.toUserId == request.auth.uid);

      // Only the sender can create; must be "pending", can't connect to self
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(
                         ['fromUserId', 'fromUserName', 'fromUserAge', 'fromUserGender',
                          'fromUserBio', 'fromUserPhotoURL', 'fromUserInterests',
                          'toUserId', 'toUserName', 'status', 'createdAt'])
                    && request.resource.data.fromUserId == request.auth.uid
                    && request.resource.data.toUserId is string
                    && request.resource.data.toUserId.size() > 0
                    && request.resource.data.fromUserId != request.resource.data.toUserId
                    && request.resource.data.status == 'pending';

      // Only the receiver can accept / reject (change status only)
      allow update: if request.auth != null
                    && resource.data.toUserId == request.auth.uid
                    && request.resource.data.status in ['accepted', 'rejected']
                    && request.resource.data.fromUserId == resource.data.fromUserId
                    && request.resource.data.toUserId == resource.data.toUserId
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.keys().hasOnly(
                         ['fromUserId', 'fromUserName', 'fromUserAge', 'fromUserGender',
                          'fromUserBio', 'fromUserPhotoURL', 'fromUserInterests',
                          'toUserId', 'toUserName', 'status', 'createdAt']);

      // Sender or receiver can delete
      allow delete: if request.auth != null
                    && (resource.data.fromUserId == request.auth.uid
                        || resource.data.toUserId == request.auth.uid);
    }

    // ── Invites ──────────────────────────────────────────
    match /invites/{inviteId} {
      // Anyone can read an invite (recipients may not be logged in yet)
      allow read: if true;

      // Authenticated users can create invites they own
      allow create: if request.auth != null
                    && request.resource.data.inviterId == request.auth.uid;

      // No updates or deletes
      allow update, delete: if false;
    }

    // ── Conversations ─────────────────────────────────────
    match /conversations/{convId} {
      // Only participants can read conversations
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      // Authenticated users can create conversations they're part of
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2;

      // Only participants can update (for lastMessage, unread counts)
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      // Participants can delete conversations
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        // Only conversation participants can read messages
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        // Only participants can send messages, senderId must match auth, validate content
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() >= 1
                      && request.resource.data.text.size() <= 5000;

        // Conversation participants can delete messages
        allow delete: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }
  }
}
